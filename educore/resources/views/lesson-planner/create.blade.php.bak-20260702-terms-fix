<script>
const curriculumSel = document.getElementById('curriculumSel');
const planSections  = document.getElementById('planSections');

function updateCurriculum() {
    planSections.dataset.curriculum = curriculumSel.value;
}
curriculumSel.addEventListener('change', updateCurriculum);
updateCurriculum();

async function generateWithAI() {
    const btn   = document.getElementById('generateBtn');
    const label = document.getElementById('generateLabel');
    const spin  = document.getElementById('aiSpinner');
    const err   = document.getElementById('aiError');
    const ok    = document.getElementById('aiSuccess');

    const subject    = document.getElementById('subjectSel').options[document.getElementById('subjectSel').selectedIndex]?.dataset.name ?? '';
    const classLevel = document.getElementById('classLevelSel').options[document.getElementById('classLevelSel').selectedIndex]?.dataset.name ?? '';
    const section    = document.getElementById('classLevelSel').options[document.getElementById('classLevelSel').selectedIndex]?.dataset.section ?? 'junior_secondary';
    const topic      = document.getElementById('topicInp').value.trim();
    const subtopic   = document.getElementById('subtopicInp').value.trim();
    const curriculum = curriculumSel.value;
    const duration   = document.getElementById('durationInp').value;
    const week       = document.getElementById('weekInp')?.value ?? '';

    if (!subject || !classLevel || !topic) {
        err.textContent = 'Please fill in Subject, Class Level, and Topic before generating.';
        err.style.display = 'block';
        ok.style.display = 'none';
        return;
    }

    btn.disabled = true;
    label.textContent = 'Generating…';
    spin.style.display = 'inline-block';
    err.style.display = 'none';
    ok.style.display = 'none';

    try {
        const res = await fetch('{{ route("lesson-planner.generate") }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').content,
                'Accept': 'application/json',
            },
            body: JSON.stringify({ subject, class_level: classLevel, topic, subtopic, curriculum_type: curriculum, section, duration_minutes: duration, week, term: '' }),
        });

        const json = await res.json();
        if (!json.success) throw new Error(json.message ?? 'Unknown error');

        // Fill in the fields
        Object.entries(json.data).forEach(([key, val]) => {
            const el = document.getElementById('f_' + key) ?? document.getElementById('f_' + key + '_british');
            if (el) el.value = val;
        });

        document.getElementById('aiGeneratedFlag').value = '1';
        ok.style.display = 'block';
        document.querySelector('.lp-card')?.scrollIntoView({ behavior: 'smooth' });
    } catch (e) {
        const msg = e.message ?? '';
        let friendly = '⚠ ' + msg;

        if (msg.includes('daily') || msg.includes('Daily') || msg.includes('30 req') || msg.includes('requests per day')) {
            friendly = '🚫 Groq daily limit reached (30 free requests/day). Wait until tomorrow or use a paid API key.';
        } else if (msg.includes('cut off mid-generation') || msg.includes('token-per-minute')) {
            friendly = '⏳ Groq hit its per-minute token limit. Wait 60 seconds, then try again.';
        } else if (msg.includes('rate-limited') || msg.includes('rate limit')) {
            friendly = '⏳ AI provider is rate-limited. Please wait 30–60 seconds and try again.';
        } else if (msg.includes('All AI providers failed')) {
            // Parse individual provider failures for a cleaner display
            const parts = msg.replace('All AI providers failed — ', '').split(' | ');
            friendly = '⚠ All AI providers failed:<ul style="margin:6px 0 0 16px;padding:0">'
                + parts.map(p => {
                    if (p.includes('daily') || p.includes('cut off')) return '<li>' + p.split(':')[0] + ': token limit reached</li>';
                    if (p.includes('429') || p.includes('rate')) return '<li>' + p.split(':')[0] + ': rate limited — try later</li>';
                    if (p.includes('connect') || p.includes('cURL')) return '<li>' + p.split(':')[0] + ': not available</li>';
                    if (p.includes('not configured')) return '<li>' + p.split(':')[0] + ': API key not set</li>';
                    return '<li>' + p.substring(0, 80) + '</li>';
                }).join('') + '</ul>';
            err.innerHTML = friendly;
            err.style.display = 'block';
            return;
        }

        err.textContent = friendly;
        err.style.display = 'block';
    } finally {
        btn.disabled = false;
        label.textContent = 'Generate with AI';
        spin.style.display = 'none';
    }
}
</script>
@endsection
